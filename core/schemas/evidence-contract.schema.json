{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Contract",
  "type": "object",
  "required": ["milestone", "evidence"],
  "properties": {
    "milestone": { "type": "string", "minLength": 1 },
    "proofTarget": { "type": "string" },
    "claim": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "owner", "path", "passCriteria"],
        "properties": {
          "name": { "type": "string" },
          "artifactType": { "type": "string" },
          "owner": { "type": "string" },
          "path": { "type": "string" },
          "passCriteria": { "type": "string" },
          "proofRole": { "type": "string" },
          "staleAfter": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "internalEvidence": {
      "type": "array",
      "items": {
        "type": ["object", "string"],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
