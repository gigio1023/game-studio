{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Milestone Contract",
  "type": "object",
  "required": [
    "id",
    "name",
    "stage",
    "directionSource",
    "selectedConcept",
    "goal",
    "proofTarget",
    "proofBudget",
    "researchQuestion",
    "experienceHypothesis",
    "deliverables",
    "qualityCriteria",
    "nonGoals",
    "cutCandidates",
    "requiredInternalEvidenceArtifacts",
    "qaWalkthrough",
    "reviewRoles",
    "gateReviewers",
    "gates",
    "risks",
    "fallbackProof",
    "exitDecision"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "directionSource": {
      "enum": ["direction-carry-in", "taste-to-game", "brownfield-unknown"]
    },
    "selectedConcept": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "proofTarget": { "type": "string", "minLength": 1 },
    "proofBudget": {
      "type": ["object", "array", "string"]
    },
    "researchQuestion": { "type": "string", "minLength": 1 },
    "experienceHypothesis": { "type": "string", "minLength": 1 },
    "deliverables": {
      "type": "array",
      "items": {
        "type": ["object", "string"],
        "additionalProperties": true
      }
    },
    "qualityCriteria": {
      "type": "array",
      "items": {
        "type": ["object", "string"],
        "additionalProperties": true
      }
    },
    "nonGoals": { "type": "array", "items": { "type": "string" } },
    "cutCandidates": { "type": "array", "items": { "type": "string" } },
    "requiredInternalEvidenceArtifacts": {
      "type": "array",
      "items": {
        "type": ["object", "string"],
        "additionalProperties": true
      }
    },
    "gates": { "type": "array", "items": { "type": "string" } },
    "reviewRoles": { "type": "array", "items": { "type": "string" } },
    "gateReviewers": { "type": "array", "items": { "type": "string" } },
    "qaWalkthrough": {
      "type": ["array", "string"],
      "items": { "type": "string" }
    },
    "fallbackProof": { "type": "string", "minLength": 1 },
    "exitDecision": { "enum": ["READY", "CONCERNS", "NOT_READY"] },
    "risks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
